{
  "name": "ghost-build",
  "private": true,
  "packageManager": "pnpm@10.27.0",
  "type": "module",
  "imports": {
    "#/*": "./src/*"
  },
  "scripts": {
    "dev": "vite dev --port 3000",
    "build": "vite build && tsc --noEmit",
    "preview": "vite preview",
    "test": "vitest run",
    "deploy": "echo \"GhostBuild is retired; deploy SummonGhost Code from ../summon-ghost instead.\" && exit 1",
    "cf-typegen": "wrangler types"
  },
  "dependencies": {
    "@ai-sdk/openai": "^3.0.63",
    "@better-auth/memory-adapter": "^1.6.10",
    "@cloudflare/ai-chat": "^0.6.2",
    "@cloudflare/shell": "^0.3.6",
    "@cloudflare/think": "^0.5.3",
    "@cloudflare/vite-plugin": "^1.26.0",
    "@tailwindcss/vite": "^4.1.18",
    "@tanstack/react-devtools": "latest",
    "@tanstack/react-query": "^5.100.10",
    "@tanstack/react-router": "latest",
    "@tanstack/react-router-devtools": "latest",
    "@tanstack/react-router-ssr-query": "latest",
    "@tanstack/react-start": "latest",
    "@tanstack/router-plugin": "^1.132.0",
    "agents": "^0.12.3",
    "ai": "^6.0.177",
    "better-auth": "^1.6.10",
    "lucide-react": "^0.545.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "tailwindcss": "^4.1.18",
    "workers-ai-provider": "^3.1.14",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/typography": "^0.5.16",
    "@tanstack/devtools-vite": "latest",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^22.10.2",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^6.0.1",
    "jsdom": "^28.1.0",
    "typescript": "^6.0.2",
    "vite": "^8.0.0",
    "vitest": "^4.1.5",
    "wrangler": "^4.70.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "lightningcss"
    ]
